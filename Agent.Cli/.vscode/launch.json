        {
            "name": "Debug Agent.Cli (external terminal)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/Agent.Cli/bin/Debug/net10.0/Agent.Cli",
            "args": ["Agent"],
            "console": "externalTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}
